---
import { posts } from "./posts";
---

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>XAAANE @ BLOG</title>
		<meta name="description" content="writing about whatever" />
		<meta property="og:title" content="XAAANE @ BLOG" />
		<meta property="og:description" content="writing about whatever" />
		<meta property="og:image" content="/xaaane-og.png" />
		<link rel="icon" type="image/png" href="/flavicon.png" />
		<link rel="icon" type="image/png" href="/flavicon.png" />
		<style>
			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			body {
				font-family: "Times New Roman", Times, serif;
				background: #000;
				color: #fff;
				padding: 40px 20px;
				line-height: 1.6;
				background-image: url("/griptape.gif");
				background-attachment: fixed;
			}

			.container {
				max-width: 900px;
				margin: 0 auto;
			}

			h1 {
				font-size: 2.5rem;
				margin-bottom: 1rem;
				border-bottom: 2px solid #bfff00;
				padding-bottom: 0.5rem;
				line-height: 1.1;
			}

			.intro {
				margin-bottom: 3rem;
				font-size: 1.1rem;
				color: #ccc;
			}

			.posts-grid {
				display: grid;
				gap: 2rem;
			}

			.post-card {
				background: #111;
				border: 1px solid #333;
				padding: 1.5rem;
				transition: all 0.2s;
			}

			.post-card:hover {
				border-color: #bfff00;
				transform: translateY(-2px);
			}

			.post-date {
				display: inline-block;
				background: #bfff00;
				color: #000;
				padding: 0.25rem 0.75rem;
				font-size: 0.8rem;
				font-weight: bold;
				margin-bottom: 1rem;
				text-transform: uppercase;
			}

			.post-title {
				font-size: 1.5rem;
				margin-bottom: 0.5rem;
			}

			.post-title a {
				color: #fff;
				text-decoration: none;
			}

			.post-title a:hover {
				color: #bfff00;
			}

			.post-excerpt {
				color: #aaa;
			}

			.back-link {
				margin-top: 3rem;
				text-align: center;
			}

			.back-link a {
				color: #fff;
				text-decoration: none;
				border-bottom: 1px solid #fff;
			}

			.back-link a:hover {
				color: #bfff00;
				border-color: #bfff00;
			}

			.blog-link-wrapper,
			.blog-link-wrapper:visited {
				text-decoration: none;
				color: white;
			}

			.blog-link-wrapper:hover h2,
			.blog-link-wrapper:visited:hover h2 {
				color: #bfff00;
			}

			.tldr {
				color: #bfff00;
				font-weight: bold;
			}

			@media (max-width: 768px) {
				h1 {
					font-size: 2rem;
				}
			}
		</style>
	</head>
	<body>
		<div class="container" style="overflow-x: hidden; padding-top:20px;">
			<!-- <h1 style="text-wrap:nowrap;">Blogger</h1> -->

			<!-- <div class="intro">
				<p>Explore my useless thoughts about absolutely nothing important</p>
			</div> -->

			<div class="posts-grid">
				{
					posts.toReversed().map((post) => (
						<a class="blog-link-wrapper" href={`/blog/${post.slug}`}>
							<article class="post-card">
								<span class="post-date">{post.displayDate}</span>
								<h2 class="post-title">{post.title}</h2>
								<p class="post-excerpt">
									<span class="tldr">tl;dr</span> - {post.tldr}
								</p>
							</article>
						</a>
					))
				}
			</div>

			<div class="back-link">
				<a href="/">← Back to Home</a>
			</div>
		</div>
	</body>
</html>
